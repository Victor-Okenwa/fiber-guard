{
  "name": "fiberguard-vscode",
  "displayName": "FiberGuard",
  "description": "Fiber node diagnostics in VS Code: health, channels, peers, payment failure analysis, and can-i-pay checks.",
  "version": "0.0.1",
  "license": "MIT",
  "publisher": "fiberguard",
  "type": "module",
  "main": "./dist/extension.cjs",
  "icon": "extension-icon.png",
  "galleryBanner": {
    "color": "#fff",
    "theme": "light"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "fiber",
    "nervos",
    "ckb",
    "lightning",
    "diagnostics",
    "payment-channels",
    "blockchain"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Victor-Okenwa/fiber-guard.git",
    "directory": "apps/vscode"
  },
  "bugs": {
    "url": "https://github.com/Victor-Okenwa/fiber-guard/issues"
  },
  "homepage": "https://github.com/Victor-Okenwa/fiber-guard#readme",
  "activationEvents": [],
  "contributes": {
    "configuration": {
      "title": "FiberGuard",
      "properties": {
        "fiberguard.nodeUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8227",
          "description": "Fiber node JSON-RPC endpoint."
        }
      }
    },
    "commands": [
      {
        "command": "fiberguard.nodeStatus",
        "category": "FiberGuard",
        "title": "Health Details",
        "icon": "$(heart)",
        "tooltip": "Assess node health score, diagnostics, and recommendations"
      },
      {
        "command": "fiberguard.canIPay",
        "category": "FiberGuard",
        "title": "Can I Pay?",
        "icon": "$(credit-card)",
        "tooltip": "Check invoice success probability and blockers before sendPayment"
      },
      {
        "command": "fiberguard.diagnosePayment",
        "category": "FiberGuard",
        "title": "Diagnose Payment",
        "icon": "$(search-fuzzy)",
        "tooltip": "Inspect a payment hash and show structured failure diagnostics"
      },
      {
        "command": "fiberguard.viewPayments",
        "category": "FiberGuard",
        "title": "View All Payments",
        "icon": "$(list-flat)",
        "tooltip": "Open a table of recent payments with amount, fee, and status"
      },
      {
        "command": "fiberguard.refresh",
        "category": "FiberGuard",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "fiberguard.copyValue",
        "title": "Copy",
        "icon": "$(copy)"
      },
      {
        "command": "fiberguard.copyPeerAddress",
        "title": "Copy Address",
        "icon": "$(copy)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "fiberguard",
          "title": "FiberGuard",
          "icon": "$(shield)"
        }
      ]
    },
    "views": {
      "fiberguard": [
        {
          "id": "fiberguard.explorer",
          "name": "Node Explorer",
          "icon": "$(pulse)"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "fiberguard.nodeStatus",
          "when": "view == fiberguard.explorer",
          "group": "navigation@1"
        },
        {
          "command": "fiberguard.canIPay",
          "when": "view == fiberguard.explorer",
          "group": "navigation@2"
        },
        {
          "command": "fiberguard.diagnosePayment",
          "when": "view == fiberguard.explorer",
          "group": "navigation@3"
        },
        {
          "command": "fiberguard.viewPayments",
          "when": "view == fiberguard.explorer",
          "group": "navigation@4"
        },
        {
          "command": "fiberguard.refresh",
          "when": "view == fiberguard.explorer",
          "group": "navigation@5"
        }
      ],
      "view/item/context": [
        {
          "command": "fiberguard.copyValue",
          "when": "view == fiberguard.explorer && viewItem == copyableChannel",
          "group": "inline@1"
        },
        {
          "command": "fiberguard.copyValue",
          "when": "view == fiberguard.explorer && viewItem == copyablePeer",
          "group": "inline@1"
        },
        {
          "command": "fiberguard.copyPeerAddress",
          "when": "view == fiberguard.explorer && viewItem == copyablePeer",
          "group": "inline@2"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "build:release": "turbo run build --filter=fiberguard-vscode...",
    "dev": "node esbuild.mjs --watch",
    "vscode:prepublish": "pnpm run build:release",
    "prepackage": "pnpm run build:release",
    "package": "vsce package --no-dependencies",
    "publish:marketplace": "vsce publish --no-dependencies",
    "publish:openvsx": "ovsx publish --no-dependencies",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ."
  },
  "dependencies": {},
  "devDependencies": {
    "@fiberguard/diagnostics": "workspace:*",
    "@fiberguard/fiber-rpc": "workspace:*",
    "@fiberguard/shared": "workspace:*",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.25.0",
    "ovsx": "^0.10.8",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
