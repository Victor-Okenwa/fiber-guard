{
  "name": "fiberguard",
  "private": true,
  "packageManager": "pnpm@10.18.3",
  "scripts": {
    "dev": "turbo dev",
    "dev:watch": "turbo run dev --log-order=grouped --ui=tui",
    "dev:shared": "turbo run dev --filter=@fiberguard/shared",
    "dev:fiber-rpc": "turbo run dev --filter=@fiberguard/fiber-rpc",
    "dev:diagnostics": "turbo run dev --filter=@fiberguard/diagnostics",
    "dev:web": "turbo run dev --filter=@fiberguard/web",
    "dev:vscode": "turbo run dev --filter=fiberguard-vscode",
    "package:vscode": "pnpm --filter fiberguard-vscode run package",
    "publish:vscode:marketplace": "pnpm --filter fiberguard-vscode run publish:marketplace",
    "publish:vscode:openvsx": "pnpm --filter fiberguard-vscode run publish:openvsx",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "biome check .",
    "format": "biome check --write .",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
